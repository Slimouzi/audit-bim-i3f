# =============================================================================
# Configuration MCP Audit BIM I3F
# =============================================================================

# --- BIMData API : authentification (un des trois modes) -------------------
# Mode 1 — Clé API (recommandé pour scripts backend)
BIMDATA_API_KEY=

# Mode 2 — OAuth2 client_credentials (alternative)
BIMDATA_CLIENT_ID=
BIMDATA_CLIENT_SECRET=

# Mode 3 — Bearer token déjà acquis (typiquement injecté par un viewer)
# BIMDATA_ACCESS_TOKEN=

# --- Endpoints BIMData ------------------------------------------------------
BIMDATA_BASE_URL=https://api.bimdata.io
BIMDATA_IAM_URL=https://iam.bimdata.io/auth/realms/bimdata/protocol/openid-connect/token

# Smart Views : route relative à BIMDATA_BASE_URL, suffixée à
# /cloud/{cloud_id}/project/{project_id}. Ajustable si la convention diffère.
BIMDATA_SMARTVIEW_PATH=/smart-view

# --- Cible par défaut (surchargeable via tool MCP set_active_model) --------
BIMDATA_CLOUD_ID=
BIMDATA_PROJECT_ID=
BIMDATA_MODEL_ID=

# --- Documents Maître d'Ouvrage -------------------------------------------
# Chemins par défaut vers les 3 livrables du CCH BIM I3F (surchargeables via
# le tool MCP set_owner_documents).
I3F_CCH_PDF=/Users/stani/code/MCP/Documents maître d'ouvrage/Cahier des annexes CCH Bim I3F V3.6 - Juil 24.pdf
I3F_DATA_SPEC_XLSX=/Users/stani/code/MCP/Documents maître d'ouvrage/Annexe Spécification des données I3F simplifiée - CCH 2021 V3.7 TDB.xlsx
I3F_NAMING_SPEC_XLSX=/Users/stani/code/MCP/Documents maître d'ouvrage/Annexe Nommage IFC 3F CCH 2021 V3.6 SHAB SU.xlsx

# --- Sortie ----------------------------------------------------------------
AUDIT_OUTPUT_DIR=./out
